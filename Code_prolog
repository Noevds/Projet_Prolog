% Gestion des erreurs d'entrées utilisateurs

% Gestion de la sortie du programme à la demande de l'utilisateur 
test_exit(T) :- T == exit -> !, throw("Il semble qu'il n'y a pas d'erreur. Vous avez demandé au programme de s'arrêter. Pour le relancer, veuillez exécuter la fonction main.") ; true.

% Vérifie et gère une entrée qui devrait être un chiffre mais qui ne l'est pas
test_nombre(X) :- not(number(X)) -> !, throw( "Il semble qu'une erreur se soit produite car vous avez entré une valeur non numérique. Veuillez relancer le programme avec 'main'.") ; true.

% Vérifie si une valeur vaut 0 alors qu'elle ne devrait pas
test_0(X) :-  X == 0 ->  !, throw("Il est important de noter qu'on ne peut pas diviser par zéro. Dans ces circonstances, le programme ne peut malheureusement pas continuer à fonctionner. Il faut le relancer avec 'main'") ; true.

% Vérifie si une des entrée est 'pourquoi' dans un prédicat de gestion du mot clé pourquoi
test_pourquoi(P) :- P == pourquoi ->  !, throw("Nous aimerions répondre une seconde fois à votre question 'pourquoi', mais malheureusement nous n'en sommes pas encore capables (on espère remplacer Chat GPT un jour, mais il y a encore du chemin). Veuillez relancer le programme avec 'main'. Désolé pour cela ! ") ; true.


% Programme principal

% Gère la récupération de CT de forme 1
recuper_CT(CT, 1) :- !,
    writeln("Vous avez indiqué que CT = a. Quelle est la valeur de a ?"),
    read(E),
    test_exit(E),!,(test_pourquoi_CT_1(CT,E,1);!, test_nombre(E),CT = E).

% Gère la récupération de CT de forme 2
recuper_CT(CT, 2) :-
    writeln("Vous avez indiqué que CT=a × q + b. Quelle est la valeur de a ?"),
    read(AT), test_exit(AT),test_0(AT),(test_pourquoi_CT_2(A,AT,2,a), ATT = A ; !, test_nombre(AT), ATT=AT),
    writeln("Et la valeur de b ? "),
    read(BT),test_exit(BT), (test_pourquoi_CT_2(B,BT,2,b), BTT = B; test_nombre(BT), BTT=BT),
    CT = [+,[*,ATT,q],BTT].


% Gère la récupération de la fonction de demande (PQ)
recuper_PQ(PQ) :-
    writeln("La fonction de demande du monopole est de la forme a × q + b, où b peut prendre la valeur 0. Pouvez-vous me fournir la valeur de a (non nulle) pour cette fonction ? "),
    read(A),
    test_exit(A), test_0(A),(test_pourquoi_PQ(a,A,AT), ATT = AT ; !, test_nombre(A), ATT=A),
    writeln("Et la valeur de b ? "),
    read(B), (test_pourquoi_PQ(b,B,BT), BTT = BT ; !, test_nombre(B), BTT=B),
    test_exit(B),
    PQ = [+,[*,ATT,q],BTT].

% Fonction principale de récupération des données du coût total (CT), de la demande (PQ) et des coûts fixes (CF)
recuper_donne(CT, PQ, CFF) :- 
    writeln("Quelle est la forme de la fonction de coût total (CT) de la firme dominante parmi : "),
    writeln("1 : CT = a"),
    writeln("2 : CT = a x q + b"),
    writeln("a et b peuvent prendre la valeur 0"),
    read(Forme),test_exit(Forme),
    (test_pourquoi_CTM(Forme2,Forme); !, test_nombre(Forme),Forme2=Forme), (   not(between(1,2,Forme2)) ->  throw("Vous avez saisi une valeur qui n'est pas dans l'intervalle [1,2]. Veuillez relancer le programme en utilisant la commande main."); true),
    
        % Appel à recuper_CT en fonction de la Forme sélectionnée
        recuper_CT(CT, Forme2),
    
    % Récupération de la fonction de demande (PQ)
    recuper_PQ(PQ),
    
    % Récupération du coût fixe de la firme entrante (CF)
    writeln("Pouvez-vous me donner le coût fixe de la firme entrante (CF) ?"),
    read(CF),test_exit(CF),
    (test_pourquoi_PQ(c,CF,CFF); !, test_nombre(CF),CFF=CF),
    
    % Vérification et validation des entrées par l'utilisateur
    write("La firme dominante a : "), transforme(CT), write(" comme fonction de coût total et "), transforme(PQ), writeln(" comme fonction de demande. "),
    write("La firme entrante supporte des coûts à hauteur de : "), writeln(CFF),
    writeln("Validez-vous ces données ? (oui, non)"),
    read(Validation),
    test_exit(Validation), pourquoi_Validation(Validation,V2),
    (V2 = non, recuper_donne(_, _, _); V2 = oui, !; throw("Une erreur inattendue est survenue dans votre entrée. Veuillez relancer le programme avec 'main'.")).

