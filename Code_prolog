% Lit une phrase
lire_phrase(L):- lire(Phrase), name(Phrase,Lphrase),divise(Lphrase,L),!.

% divise une phrase en chaine de caractère dans une liste
divise(Chaine,[MotL|Liste]) :- append(Mot,[32|Reste],Chaine),
    name(MotL,Mot),
    divise(Reste,Liste).

divise(DernierMot,[DernierMotL]):- name(DernierMotL,DernierMot).

% lit une chaine de caractères
lire(String):- read_line_to_codes(user_input, Codes), string_codes(String, Codes).

% Ecrit une chaine de caractères à partir d'une liste
ecrire([]) :- nl.
ecrire([X|L]) :- write(X), write(" "), ecrire(L).


