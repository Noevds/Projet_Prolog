% Outils 
    
% Définition de l'expression Rm(Q) : 
calcul_Rm(RT,R_rmarg) :-deriv(RT, R_rmarg),!.%simplifie(Result_rmarg,R_rmarg).

% Définition de l'expression Cm(Q) :
calcul_Cm(CT, R_cmarg) :-deriv(CT, R_cmarg),!.

% Définition de l'expression RT(Q) = Q * P(Q) :
rtot([+,[*,A,q],B],R) :- R = [+,[*,A,[*,q,q]],[*,B,q]] .

% Calcul PM :
calcul_P(PQ,Q, Result_dr) :- remplacer([q,Q],PQ,PQQ), calcul(PQQ,Result_dr).

% Calcul de QM :
test_b(Rm,Cm,Inf,Sup,Q) :- (   between(Inf,Sup,Q) ,  %on remplace le q inconnu avec le Q trouvé en bas qui réalise l'équation , pour le mettre dans l'équation Rm pour donner RmQ , apres , on calcule RmQ pour donner Rm calculé qui est RmQ
    remplacer([q,Q],Rm,RmQ), calcul(RmQ,RmC),
    remplacer([q,Q],Cm,CmQ), calcul(CmQ,CmC),
    RmC=:= CmC ; throw("Désolé, une erreur inatendue avec les bornes s'est produite, il semble que q n'est pas dans votre intervale, le programme doit être relancé")).

calcul_QM(Rm,Cm,Q) :- 
        writeln("Connaissez-vous la quantité produite par la firme en monopole ? (oui,non)"), read(Validation),test_exit(Validation),test_pourquoi_oui_non_vq(Validation,V3),
    (   V3 = non , write("La valeur de la borne inférieur de l'estimation que vous avez pour la production de la firme en monopole : "), 
    read(Inf),(test_pourquoi_vq(inférieur,Inf,I) ; !, test_nombre(Inf), I=Inf), write(" et la valeur de la borne supérieure : "), read(Sup), (test_pourquoi_vq(supérieure,Sup,S) ; !, test_nombre(Sup), S=Sup),
    test_b(Rm,Cm,I,S,Q);V3=oui, write("Entrez la valeur de q ici : ") , read(Q), test_exit(Q), test_nombre(Q) ; throw("Une erreur inconue s'est produite")).

% Calculer le profit :
calcul_pi(P,Q,CT,Pi) :- remplacer([q,Q],CT,CTQ), calcul(CTQ,Cout), PQ is P*Q, Pi is PQ - Cout.

% Calcul la demande restante :
calcul_DR([+,[*,A,q],_] , PM , DR) :- DR = [+, [*,A,q], PM].

% Calcul la valeur de la quantité pour la firme entrante
calcul_Qe(C, [+, [*,A,q], PM],Result_Qe) :-  calcul([/,[-,C,PM], [*, 2, A]],Result_Qe).

% Permet de dériver une fonction
deriv(C1,R):-number(C1),R=0,!.
deriv(q,R):-not(number(q)),R=1.
deriv([Op,N1,N2],R):-member(Op,[+,-]), deriv(N1,R1),deriv(N2,R2),R=[Op,R1,R2].
deriv([Op,N1,N2],R):-member(Op,[*]), deriv(N1,R1),deriv(N2,R2),R=[+,[*,R1,R2],[*,N1,R2]].
deriv([Op,N1,N2],R):-member(Op,[/]), deriv(N1,R1),deriv(N2,R2),R=[/,[-,[*,R1,N2],[*,N1,R2]],[*,N2,N2]].

% remplace la variable X dans l'équation donnée sous forme de liste
remplacer([A,B],X,R) :- not(is_list(X)),(X == A -> R is B ; R is X) .
remplacer(A,[X,Y,Z],[X,T1,T2]) :- remplacer(A,Y,T1),remplacer(A,Z,T2) .

% Permet de calculer une expression
calcul(N,N):-number(N).
calcul([+,A,B],R):-calcul(A,RA),calcul(B,RB),R is RA+RB.
calcul([-,A,B],R):-calcul(A,RA),calcul(B,RB),R is RA-RB.
calcul([*,A,B],R):-calcul(A,RA),calcul(B,RB),R is RA*RB.
calcul([/,A,B],R):-calcul(A,RA),calcul(B,RB),R is RA/RB.

% Fonction pour passer de la forme péfixée à infixée
transforme([Op, A,B]):- operator(Op), !, write('('), transforme(A), write(' '), write(Op), write(' '), transforme(B), write(')').
transforme(X) :- number(X), !, write(X).
transforme(X) :- atom(X), !, write(X).
operator(+).
operator(-).
operator(*).
operator(/).
