    recuper_donne(CT, PQ, C),
    
    % Calcul du système de l'entreprise dominante PM* et QM*
    calcul_Cm(CT, Cm), 
    rtot(PQ, RTM), 
    calcul_Rm(RTM, RmM), 
    calcul_QM(RmM, Cm, QM), 
    calcul_P(PQ, QM, PM), 
    calcul_pi(PM, QM, CT, PiM), 

    % Calcul du système de l'entreprise entrante
    calcul_DR(PQ, PM, DR), 
    calcul_Qe(C, DR, QE), 
    QT is QE + QM, 
