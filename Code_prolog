% Gestion de l'entrée du mot clé "pourquoi" par l'utilisateur pour les coûts totaux de la forme 1 et 2
test_pourquoi_CT_1(E,Phrase,1) :- (Phrase == pourquoi -> write("car vous avez indiqué que la foncton de coût total de la firme dominante est de la forme ") , write(1), writeln(" et nous avons besoin de la valeur de a pour pouvoir créer la fonction au format [oppérateur,opperande,opperande], afin  de pouvoir réaliser nos calculs "),writeln("Entrer ici la valeur de a, qui est un réel non nul : "),
    read(E),test_exit(E),test_pourquoi(E),!, test_nombre(E)
; fail).

test_pourquoi_CT_2(AF,Phrase,2,Valeur):- (Phrase == pourquoi -> write("car vous avez indiqué que la fonction de coût total de la firme dominante est de la forme ") , write(2), writeln(" et nous avons besoin des valeurs de a et de b pour pouvoir créer la fonction au format [oppérateur,opperande,opperande], afin  de pouvoir réaliser nos calculs "),write("Entrer ici la valeur de "),writeln(Valeur),
    read(AF),test_exit(AF),test_pourquoi(AF),!,test_nombre(AF)
; fail).

% Gestion de l'entrée du mot clé "pourquoi" par l'utilisateur pour comprendre la forme du coût total
test_pourquoi_CTM(Valeur, Entree) :- (Entree == pourquoi -> 
                                     write("Pour que notre programme puisse effectuer des calculs de manière correcte, il est impératif que la fonction soit de forme polynomiale de degré 1 ou 2. Malheureusement, nous n'avons pas encore réussi à étendre nos fonctionalités au-delà d'un polynôme du second degré.") , 
                                     write("Ainsi, souhaitez vous travailler avec la forme 1 ou 2, pour rappel : "),
                                         writeln("1 : CTM = a"),
                                         writeln("2 : CTM = a x q + b"),
                                         writeln("a et b peuvent prendre la valeur 0"), 
                                     read(Valeur),test_pourquoi(Valeur); fail).


% Gestion de l'entrée du mot clé "pourquoi" par l'utilisateur pour la fonction de demande du monopole
test_pourquoi_PQ(Valeur,Entree,Retour) :- (Entree == pourquoi -> write("Pour que notre programme puisse étudier une fonction de demande, celle-ci doit être de la forme a × q + b. Malheureusement, nous ne prenons pas en charge les formes plus complexes pour le moment. Nous avons besoin des valeurs de aa (représentant le consentement maximal à payer des consommateurs) et de bb (qui indique la taille du marché) pour pouvoir créer la fonction au format [opérateur, opérande, opérande], ce qui nous permettra d'effectuer les calculs nécessaires. "), write("Entrez la valeur de "),writeln(Valeur),
                                              read(Retour),test_exit(Retour),test_pourquoi(Retour),!,test_nombre(Retour) ; fail).

% Gestion de l'entrée du mot clé "pourquoi" par l'utilisateur pour la validation de ses entrées
pourquoi_Validation(P,R) :-  (P == pourquoi -> write("Afin de garantir l'exactitude de vos entrées, veuillez répondre par 'oui' ou 'non' ci-dessous."), read(Valeur),test_pourquoi(R),R=Valeur; R=P).

% Gestion de l'entrée du mot clé "pourquoi" par l'utilisateur pour l'entrée sur la valeur des quantités du monopole
test_pourquoi_vq(Valeur,Entree,Retour) :- (Entree == pourquoi -> write("Comme vous avez mentionné que la valeur de q est inconnue et doit être calculée, et étant donné que Prolog n'est pas optimisé pour la résolution d'équations, nous devons limiter notre recherche en utilisant la prédicat between. Quelle est la valeur de la borne supérieure que nous devons utiliser pour cette recherche ?"),writeln(Valeur),
                                              read(Retour),test_exit(Retour),test_pourquoi(Retour),!,test_nombre(Retour) ; fail).

% Gestion de l'entrée du mot clé "pourquoi" par l'utilisateur pour expliquer pourquoi nous demandons si la valeur de q monopole est connue
test_pourquoi_oui_non_vq(Entree,Retour) :- (Entree == pourquoi -> write("Pour nous aider à déterminer si nous devons calculer q, veuillez indiquer votre réponse par 'oui' ou 'non'"),
                                              read(Retour),test_exit(Retour),test_pourquoi(Retour); Retour = Entree).

